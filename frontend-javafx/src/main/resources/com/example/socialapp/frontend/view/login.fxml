<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.PasswordField?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<BorderPane xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" 
            fx:controller="com.example.socialapp.frontend.controller.LoginController"
            styleClass="login-root"
            stylesheets="@styles.css">
    
    <!-- Background container with centered card -->
    <center>
        <StackPane>
            <!-- Main centered container -->
            <VBox alignment="CENTER" spacing="0" styleClass="login-container">
                
                <!-- Card-style container with rounded corners and shadow -->
                <VBox alignment="TOP_CENTER" spacing="20" styleClass="login-card"
                      maxWidth="400">
                    <padding>
                        <Insets top="40" right="40" bottom="40" left="40" />
                    </padding>
                    
                    <!-- Header Section -->
                    <VBox alignment="CENTER" spacing="8">
                        <!-- Title -->
                        <Label text="Social App" styleClass="login-title" />
                        
                        <!-- Subtitle -->
                        <Label text="Content Moderation System" styleClass="login-subtitle" />
                    </VBox>
                    
                    <!-- Spacer -->
                    <Label text="" VBox.vgrow="ALWAYS" />
                    
                    <!-- Form Fields Section -->
                    <VBox spacing="15">
                        <!-- Email Label -->
                        <Label text="Email Address" styleClass="form-label" />
                        
                        <!-- Email Input -->
                        <TextField fx:id="emailField" 
                                   promptText="you@example.com"
                                   styleClass="form-input" />
                        
                        <!-- Password Label -->
                        <Label text="Password" styleClass="form-label" />
                        
                        <!-- Password Input -->
                        <PasswordField fx:id="passwordField" 
                                       promptText="Enter your password"
                                       styleClass="form-input" />
                    </VBox>
                    
                    <!-- Spacer -->
                    <Label text="" />
                    
                    <!-- Login Button -->
                    <Button fx:id="loginButton" 
                            text="Sign In"
                            styleClass="btn-primary"
                            maxWidth="Infinity"
                            mnemonicParsing="false" />
                    
                    <!-- Divider -->
                    <Label text="" styleClass="divider" />
                    
                    <!-- Account Section -->
                    <VBox spacing="10" alignment="CENTER">
                        <Label text="Don't have an account?" styleClass="account-text" />
                        <Button fx:id="registerButton" 
                                text="Create Account"
                                styleClass="btn-secondary"
                                maxWidth="Infinity"
                                mnemonicParsing="false" />
                    </VBox>
                </VBox>
            </VBox>
        </StackPane>
    </center>
</BorderPane>
