<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.control.Spinner?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextArea?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<VBox spacing="10.0" style="-fx-padding: 15;" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.example.socialapp.frontend.controller.AppealsController">
    <!-- Title -->
    <Label text="Pending Appeals Queue" style="-fx-font-weight: bold; -fx-font-size: 16;" />
    
    <!-- Appeal Count -->
    <Label fx:id="appealCountLabel" text="Appeals: 0 / 0" style="-fx-font-size: 12; -fx-text-fill: #666;" />
    
    <!-- TableView for Appeals -->
    <TableView fx:id="appealsTable" maxHeight="200.0" minHeight="150.0" prefHeight="200.0" prefWidth="1150.0">
        <columns>
            <TableColumn fx:id="userColumn" prefWidth="120.0" text="User" />
            <TableColumn fx:id="appealTypeColumn" prefWidth="100.0" text="Type" />
            <TableColumn fx:id="reasonColumn" prefWidth="450.0" text="Appeal Reason" />
            <TableColumn fx:id="createdAtColumn" prefWidth="120.0" text="Submitted" />
            <TableColumn fx:id="statusColumn" prefWidth="100.0" text="Status" />
        </columns>
    </TableView>
    
    <!-- Pagination -->
    <HBox alignment="CENTER" spacing="10.0" style="-fx-padding: 10;">
        <Label text="Page:" />
        <Spinner fx:id="pageSpinner" prefWidth="80.0" />
    </HBox>
    
    <!-- Decision Panel -->
    <VBox spacing="12.0" style="-fx-border-color: #e0e0e0; -fx-border-width: 1; -fx-padding: 15;">
        <Label text="Appeal Decision" style="-fx-font-weight: bold; -fx-font-size: 14;" />
        
        <!-- Decision Reason TextArea -->
        <Label text="Reason for Decision:" style="-fx-font-weight: bold;" />
        <TextArea fx:id="decisionReasonArea" maxHeight="60.0" prefHeight="60.0" prefRowCount="3" promptText="Enter reason for your decision..." wrapText="true" />
        
        <!-- Decision Buttons -->
        <HBox spacing="15.0" style="-fx-padding: 10 0 0 0; -fx-alignment: center;">
            <Button fx:id="approveButton" minWidth="150.0" mnemonicParsing="false" style="-fx-padding: 10 15; -fx-font-size: 12; -fx-text-fill: white; -fx-background-color: #5cb85c;" text="✓ Approve Appeal" />
            <Button fx:id="rejectButton" minWidth="150.0" mnemonicParsing="false" style="-fx-padding: 10 15; -fx-font-size: 12; -fx-text-fill: white; -fx-background-color: #d9534f;" text="✗ Reject Appeal" />
        </HBox>
    </VBox>
</VBox>
