<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<BorderPane xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.example.socialapp.frontend.controller.AdminPanelController"
            style="-fx-font-family: 'Segoe UI'; -fx-font-size: 12;">

    <!-- Top ToolBar -->
    <top>
        <ToolBar style="-fx-background-color: #2c3e50; -fx-padding: 10;">
            <Label fx:id="titleLabel" text="Admin Panel"
                   style="-fx-font-size: 18; -fx-font-weight: bold; -fx-text-fill: white;"/>
            <Separator prefWidth="100"/>
            <Button fx:id="backButton" text="← Back to Feed"
                    style="-fx-font-size: 12; -fx-padding: 8px 16px;"/>
        </ToolBar>
    </top>

    <!-- Main Content with Tabs -->
    <center>
        <TabPane fx:id="adminTabPane" tabClosingPolicy="UNAVAILABLE" style="-fx-font-size: 12;">
            <!-- User Management Tab -->
            <Tab text="User Management" style="-fx-font-size: 14;">
                <VBox spacing="10" style="-fx-padding: 15;">
                    <!-- Users Table -->
                    <VBox spacing="5">
                        <Label text="Users List" style="-fx-font-size: 14; -fx-font-weight: bold;"/>
                        <TableView fx:id="usersTable" prefHeight="400" style="-fx-font-size: 11;">
                            <columns>
                                <TableColumn fx:id="userIdColumn" text="User ID" prefWidth="150"/>
                                <TableColumn fx:id="emailColumn" text="Email" prefWidth="180"/>
                                <TableColumn fx:id="nameColumn" text="Name" prefWidth="150"/>
                                <TableColumn fx:id="rolesColumn" text="Roles" prefWidth="120"/>
                                <TableColumn fx:id="enabledColumn" text="Enabled" prefWidth="100"/>
                            </columns>
                        </TableView>
                    </VBox>

                    <!-- User Actions Section -->
                    <VBox spacing="8" style="-fx-border-color: #e0e0e0; -fx-border-width: 1; -fx-padding: 12; -fx-border-radius: 4;">
                        <Label text="User Actions" style="-fx-font-size: 13; -fx-font-weight: bold;"/>
                        
                        <Label text="Reason for Action:" style="-fx-font-size: 11; -fx-text-fill: #555;"/>
                        <TextArea fx:id="userActionReasonArea" wrapText="true" prefRowCount="3" 
                                  style="-fx-font-size: 11; -fx-control-inner-background: #f9f9f9;"
                                  disable="true"/>

                        <HBox spacing="10">
                            <Button fx:id="banUserButton" text="🚫 Ban User (Disable Account)"
                                    style="-fx-background-color: #d9534f; -fx-text-fill: white; -fx-padding: 8px 12px;"
                                    disable="true"/>
                            <Button fx:id="unbanUserButton" text="✓ Unban User (Enable Account)"
                                    style="-fx-background-color: #5cb85c; -fx-text-fill: white; -fx-padding: 8px 12px;"
                                    disable="true"/>
                        </HBox>
                    </VBox>

                    <!-- Pagination -->
                    <HBox spacing="10" alignment="CENTER">
                        <Label text="Page:"/>
                        <Spinner fx:id="usersPageSpinner" prefWidth="80"/>
                    </HBox>
                </VBox>
            </Tab>

            <!-- Appeals Review Tab -->
            <Tab text="Appeal Reviews" style="-fx-font-size: 14;">
                <VBox spacing="10" style="-fx-padding: 15;">
                    <!-- Appeals Table -->
                    <VBox spacing="5">
                        <Label text="Pending Appeals" style="-fx-font-size: 14; -fx-font-weight: bold;"/>
                        <TableView fx:id="appealsTable" prefHeight="400" style="-fx-font-size: 11;">
                            <columns>
                                <TableColumn fx:id="appealIdColumn" text="Appeal ID" prefWidth="150"/>
                                <TableColumn fx:id="reasonColumn" text="Reason" prefWidth="250"/>
                                <TableColumn fx:id="statusColumn" text="Status" prefWidth="100"/>
                                <TableColumn fx:id="createdAtColumn" text="Created At" prefWidth="120"/>
                            </columns>
                        </TableView>
                    </VBox>

                    <!-- Appeal Decision Section -->
                    <VBox spacing="8" style="-fx-border-color: #e0e0e0; -fx-border-width: 1; -fx-padding: 12; -fx-border-radius: 4;">
                        <Label text="Final Decision" style="-fx-font-size: 13; -fx-font-weight: bold;"/>
                        
                        <Label text="Admin Decision & Review:" style="-fx-font-size: 11; -fx-text-fill: #555;"/>
                        <TextArea fx:id="appealDecisionArea" wrapText="true" prefRowCount="3"
                                  style="-fx-font-size: 11; -fx-control-inner-background: #f9f9f9;"
                                  disable="true"
                                  promptText="Enter your final decision and reasoning..."/>

                        <HBox spacing="10">
                            <Button fx:id="approveAppealButton" text="✓ Approve Appeal (Unban User)"
                                    style="-fx-background-color: #5cb85c; -fx-text-fill: white; -fx-padding: 8px 12px;"
                                    disable="true"/>
                            <Button fx:id="rejectAppealButton" text="✗ Reject Appeal (Uphold Ban)"
                                    style="-fx-background-color: #d9534f; -fx-text-fill: white; -fx-padding: 8px 12px;"
                                    disable="true"/>
                        </HBox>
                    </VBox>

                    <!-- Pagination -->
                    <HBox spacing="10" alignment="CENTER">
                        <Label text="Page:"/>
                        <Spinner fx:id="appealsPageSpinner" prefWidth="80"/>
                    </HBox>
                </VBox>
            </Tab>
        </TabPane>
    </center>
</BorderPane>
