<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<BorderPane xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.example.socialapp.frontend.controller.AppealScreenController"
            style="-fx-font-family: 'Segoe UI'; -fx-font-size: 12;">

    <!-- Top ToolBar -->
    <top>
        <ToolBar style="-fx-background-color: #2c3e50; -fx-padding: 10;">
            <Label fx:id="titleLabel" text="Ban Appeal"
                   style="-fx-font-size: 18; -fx-font-weight: bold; -fx-text-fill: white;"/>
            <Separator prefWidth="100"/>
            <Button fx:id="backButton" text="← Back to Login"
                    style="-fx-font-size: 12; -fx-padding: 8px 16px;"/>
        </ToolBar>
    </top>

    <!-- Main Content -->
    <center>
        <VBox spacing="15" style="-fx-padding: 20;">
            <!-- Ban Information Section -->
            <VBox spacing="8" style="-fx-border-color: #ffcccc; -fx-border-width: 1; -fx-padding: 12; -fx-border-radius: 4; -fx-background-color: #fff5f5;">
                <Label text="Ban Information" style="-fx-font-size: 13; -fx-font-weight: bold; -fx-text-fill: #d9534f;"/>
                <Label fx:id="banReasonLabel" wrapText="true"
                       style="-fx-font-size: 12; -fx-text-fill: #333;"
                       text="Your account has been temporarily banned..."/>
                <Label text="You can submit an appeal below to request a review of this decision."
                       style="-fx-font-size: 11; -fx-text-fill: #666;"/>
            </VBox>

            <!-- Appeal Submission Section -->
            <VBox spacing="8" style="-fx-border-color: #e0e0e0; -fx-border-width: 1; -fx-padding: 12; -fx-border-radius: 4;">
                <Label text="Submit Appeal" style="-fx-font-size: 13; -fx-font-weight: bold;"/>
                
                <Label text="Why should your ban be lifted? Please provide details:"
                       style="-fx-font-size: 11; -fx-text-fill: #555;"/>
                
                <TextArea fx:id="appealReasonArea" wrapText="true" prefRowCount="5"
                          style="-fx-font-size: 11; -fx-control-inner-background: #f9f9f9;"
                          promptText="Explain why you believe your ban should be lifted. Be specific and honest about what happened."/>

                <Label text="Minimum 10 characters, maximum 1000 characters"
                       style="-fx-font-size: 10; -fx-text-fill: #999;"/>

                <Button fx:id="submitAppealButton" text="Submit Appeal"
                        style="-fx-background-color: #0275d8; -fx-text-fill: white; -fx-padding: 10px 20px; -fx-font-size: 12; -fx-font-weight: bold;"/>
            </VBox>

            <!-- Success Message -->
            <HBox style="-fx-padding: 10; -fx-border-color: #5cb85c; -fx-border-width: 1; -fx-border-radius: 4; -fx-background-color: #f0fdf4;">
                <Label fx:id="submittedMessageLabel" text="✓ Appeal submitted successfully"
                       style="-fx-font-size: 12; -fx-text-fill: #5cb85c; -fx-font-weight: bold;"
                       visible="false" managed="false"/>
            </HBox>

            <!-- Appeals History Section -->
            <VBox spacing="8">
                <Label text="Your Appeals" style="-fx-font-size: 13; -fx-font-weight: bold;"/>
                
                <Label fx:id="noAppealsLabel" text="No appeals submitted yet"
                       style="-fx-font-size: 11; -fx-text-fill: #999; -fx-padding: 15;"
                       visible="false" managed="false"/>
                
                <TableView fx:id="appealsTable" prefHeight="250" style="-fx-font-size: 11;">
                    <columns>
                        <TableColumn fx:id="appealIdColumn" text="Appeal ID" prefWidth="80"/>
                        <TableColumn fx:id="reasonColumn" text="Reason" prefWidth="250"/>
                        <TableColumn fx:id="statusColumn" text="Status" prefWidth="100"/>
                        <TableColumn fx:id="createdAtColumn" text="Submitted" prefWidth="100"/>
                    </columns>
                </TableView>

                <!-- Status Legend -->
                <HBox spacing="20" style="-fx-padding: 10; -fx-background-color: #f5f5f5; -fx-border-radius: 3;">
                    <VBox spacing="3">
                        <Label text="PENDING" style="-fx-font-weight: bold; -fx-text-fill: #ff9800;"/>
                        <Label text="Awaiting review" style="-fx-font-size: 10;"/>
                    </VBox>
                    <VBox spacing="3">
                        <Label text="APPROVED" style="-fx-font-weight: bold; -fx-text-fill: #5cb85c;"/>
                        <Label text="Ban lifted" style="-fx-font-size: 10;"/>
                    </VBox>
                    <VBox spacing="3">
                        <Label text="REJECTED" style="-fx-font-weight: bold; -fx-text-fill: #d9534f;"/>
                        <Label text="Appeal denied" style="-fx-font-size: 10;"/>
                    </VBox>
                </HBox>
            </VBox>
        </VBox>
    </center>
</BorderPane>
