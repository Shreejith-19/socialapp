<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.control.Separator?>
<?import javafx.scene.control.Spinner?>
<?import javafx.scene.control.TextArea?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Priority?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>

<BorderPane xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" 
            fx:controller="com.example.socialapp.frontend.controller.DashboardController"
            styleClass="dashboard-root"
            stylesheets="@styles.css">
    
    <!-- ============================================================================
         TOP NAVBAR
         ============================================================================ -->
    <top>
        <HBox styleClass="navbar" spacing="20" alignment="CENTER_LEFT">
            <padding>
                <Insets top="15" right="30" bottom="15" left="30" />
            </padding>
            
            <!-- App Name -->
            <Label text="Social App" styleClass="navbar-title" />
            
            <!-- Navigation spacing -->
            <Region HBox.hgrow="ALWAYS" />
            
            <!-- Right side buttons -->
            <HBox spacing="10" alignment="CENTER_RIGHT">
                <!-- Navigation Buttons -->
                <Button fx:id="myPostsStatusButton" 
                        text="My Posts"
                        styleClass="btn-navbar" />
                <Button fx:id="appealButton" 
                        text="Appeal Ban"
                        styleClass="btn-navbar-danger" />
                <Button fx:id="moderationButton" 
                        text="Moderation"
                        styleClass="btn-navbar" />
                <Button fx:id="adminButton" 
                        text="Admin"
                        styleClass="btn-navbar" />
                
                <!-- User Info and Logout -->
                <Separator styleClass="navbar-separator" />
                <Label fx:id="welcomeLabel" 
                       text="Welcome!"
                       styleClass="navbar-user" />
                <Button fx:id="logoutButton" 
                        text="Logout"
                        styleClass="btn-logout" />
            </HBox>
        </HBox>
    </top>
    
    <!-- ============================================================================
         MAIN CONTENT - Centered Feed Layout
         ============================================================================ -->
    <center>
        <VBox alignment="TOP_CENTER" spacing="0" styleClass="dashboard-container">
            <padding>
                <Insets top="20" right="20" bottom="20" left="20" />
            </padding>
            
            <!-- Create Post Card (Top Center) -->
            <VBox styleClass="card" spacing="12" maxWidth="800">
                <padding>
                    <Insets top="20" right="20" bottom="20" left="20" />
                </padding>
                
                <Label text="Create Post" styleClass="card-title" />
                
                <TextArea fx:id="postContentArea" 
                          promptText="What's on your mind?"
                          wrapText="true"
                          styleClass="post-input"
                          prefRowCount="6" />
                
                <Button fx:id="createPostButton" 
                        text="Post"
                        styleClass="btn-primary"
                        maxWidth="Infinity" />
            </VBox>
            
            <!-- Feed Section (Below Create Post) -->
            <VBox VBox.vgrow="ALWAYS" spacing="0" styleClass="feed-container" maxWidth="800">
                <!-- Feed Header -->
                <HBox styleClass="feed-header" spacing="10" alignment="CENTER_LEFT">
                    <padding>
                        <Insets top="20" right="0" bottom="15" left="0" />
                    </padding>
                    
                    <Label text="Posts Feed" styleClass="feed-title" />
                    
                    <Region HBox.hgrow="ALWAYS" />
                    
                    <Button fx:id="refreshButton" 
                            text="🔄 Refresh"
                            styleClass="btn-secondary" />
                </HBox>
                
                <!-- Scrollable Posts Feed -->
                <ScrollPane styleClass="feed-scroll" VBox.vgrow="ALWAYS">
                    <VBox fx:id="postsFeed" 
                          spacing="15"
                          styleClass="posts-list">
                        <padding>
                            <Insets top="0" right="0" bottom="20" left="0" />
                        </padding>
                    </VBox>
                </ScrollPane>
                
                <!-- Pagination -->
                <HBox alignment="CENTER" spacing="10" styleClass="pagination-bar">
                    <padding>
                        <Insets top="15" right="0" bottom="0" left="0" />
                    </padding>
                    
                    <Label text="Page:" styleClass="pagination-label" />
                    <Spinner fx:id="pageSpinner" 
                             prefWidth="80" />
                </HBox>
            </VBox>
        </VBox>
    </center>
</BorderPane>

