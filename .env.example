# Environment Variables Template for Social Media Moderation System
# Copy this file to .env and populate with actual values

# Application Configuration
APP_NAME=social-moderation-system
APP_VERSION=1.0.0

# Server Configuration
SERVER_PORT=8080
SERVER_CONTEXT_PATH=/api

# Database Configuration (PostgreSQL for Production)
DATABASE_URL=jdbc:postgresql://localhost:5432/socialapp_db
DATABASE_USER=socialapp_user
DATABASE_PASSWORD=secure_password_here
DATABASE_POOL_SIZE=20

# JWT Configuration
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production-environment-minimum-256-bits
JWT_EXPIRATION=86400000
JWT_REFRESH_EXPIRATION=604800000

# CORS Configuration
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:4200
CORS_ALLOWED_METHODS=GET,POST,PUT,DELETE,OPTIONS
CORS_ALLOW_CREDENTIALS=true

# Security Configuration
ENABLE_CORS=true
ENABLE_CSRF=false
SSL_ENABLED=false
KEY_STORE_PATH=/path/to/keystore.p12
KEY_STORE_PASSWORD=keystore_password

# Logging Configuration
LOG_LEVEL_ROOT=WARN
LOG_LEVEL_APP=INFO
LOG_FILE_PATH=logs/socialapp.log
LOG_MAX_SIZE=10MB

# Email Configuration (for future notifications)
EMAIL_ENABLED=false
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USERNAME=your-email@gmail.com
EMAIL_PASSWORD=your-app-password

# AWS Configuration (for future S3 storage)
AWS_S3_ENABLED=false
AWS_ACCESS_KEY_ID=your_access_key
AWS_SECRET_ACCESS_KEY=your_secret_key
AWS_S3_BUCKET=socialapp-bucket
AWS_REGION=us-east-1

# Redis Configuration (for future caching)
REDIS_ENABLED=false
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_TIMEOUT=1000

# Monitoring and Metrics
METRICS_ENABLED=false
METRICS_EXPORT_INTERVAL=1m

# Application Profiles
SPRING_PROFILES_ACTIVE=dev
